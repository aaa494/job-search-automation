# ============================================================
# HOW TO GET YOUR ANTHROPIC API KEY:
#   1. Go to: https://console.anthropic.com
#   2. Sign in or create an account
#   3. Click "API Keys" in the left menu
#   4. Click "Create Key", give it a name
#   5. Copy the key (starts with "sk-ant-...")
#   6. Paste it below
# ============================================================
ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# ============================================================
# LinkedIn and Indeed — NO PASSWORD NEEDED HERE
#
# These sites support "Sign in with Google".
# When you first run the script, a browser window will open.
# Just click "Sign in with Google" and log in normally.
# The script saves your session (cookies) automatically.
# Next time it runs, you'll be logged in already.
# ============================================================

# ============================================================
# GOOGLE DRIVE (optional) — stores resumes, cover letters,
# and HTML reports automatically in your Google Drive.
#
# HOW TO SET UP:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (e.g. "Job Search Bot")
#   3. Click "APIs & Services" → "Enable APIs"
#      → Search "Google Drive API" → Enable it
#   4. Go to "Credentials" → "Create Credentials"
#      → "OAuth 2.0 Client ID" → Application type: Desktop app
#   5. Click Download (JSON file)
#   6. Save it as:  credentials/google_credentials.json
#   7. Set GOOGLE_DRIVE_ENABLED=true below
#
# First run: browser opens for one-time Google authorization.
# After that: fully automatic, no interaction needed.
# ============================================================
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_FOLDER=Job Search Automation

# ============================================================
# TELEGRAM NOTIFICATIONS (optional)
# Get notified about matches, applications, errors.
#
# HOW TO SET UP:
#   1. Open Telegram → search @BotFather → /newbot
#   2. Follow prompts → copy the token (looks like 123456:ABCdef...)
#   3. Send any message to your new bot
#   4. Open in browser:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      → find "chat":{"id": <NUMBER>} — that's your CHAT_ID
#   5. Fill in below and it works immediately, no restart needed.
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
